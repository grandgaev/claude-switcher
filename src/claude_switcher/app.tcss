/* Claude-inspired dark theme. Accent #d97757 (Claude orange). */

Screen {
    background: #161513;
    color: #e8e6e3;
}

Header {
    background: #1f1d1a;
    color: #d97757;
    text-style: bold;
    height: 1;
}

Footer {
    background: #1f1d1a;
    color: #888579;
}

Footer > .footer--key {
    background: #d97757;
    color: #161513;
    text-style: bold;
}

#status-bar {
    height: 4;
    background: #1f1d1a;
    color: #e8e6e3;
    padding: 1 2;
    border-bottom: solid #2a2724;
}

#main {
    height: 1fr;
}

#left-pane {
    width: 65%;
    min-width: 60;
    border-right: solid #2a2724;
}

#right-pane {
    width: 1fr;
    min-width: 38;
    padding: 1 2;
}

DataTable {
    background: #161513;
    height: 1fr;
}

DataTable > .datatable--header {
    background: #1f1d1a;
    color: #d97757;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #d97757;
    color: #161513;
    text-style: bold;
}

DataTable > .datatable--hover {
    background: #2a2724;
}

DataTable > .datatable--odd-row {
    background: #19181655;
}

#snapshot-title {
    color: #d97757;
    text-style: bold;
    margin-top: 1;
}

#snapshot-list {
    height: auto;
    max-height: 12;
    background: #19181640;
    border: solid #2a2724;
    padding: 0 1;
}

#snapshot-list > ListItem {
    background: transparent;
    padding: 0 1;
}

#snapshot-list > ListItem.--highlight {
    background: #d9775733;
    color: #d97757;
}

/* Modal styling */
ModalScreen {
    align: center middle;
    background: #00000080;
}

#modal-box {
    background: #1f1d1a;
    border: solid #d97757;
    padding: 1 2;
    width: 60;
    height: auto;
}

#modal-title {
    color: #d97757;
    text-style: bold;
    margin-bottom: 1;
}

#modal-message {
    color: #e8e6e3;
    margin-bottom: 1;
}

#modal-input {
    background: #161513;
    border: solid #2a2724;
    color: #e8e6e3;
}

#modal-input:focus {
    border: solid #d97757;
}

#modal-buttons {
    height: 3;
    align: right middle;
    margin-top: 1;
}

#modal-buttons Button {
    margin-left: 1;
    min-width: 12;
}

Button {
    background: #2a2724;
    color: #e8e6e3;
    border: none;
}

Button:hover {
    background: #3a3633;
}

Button.-primary {
    background: #d97757;
    color: #161513;
    text-style: bold;
}

Button.-primary:hover {
    background: #e89070;
}

Button.-danger {
    background: #e76f51;
    color: #161513;
    text-style: bold;
}

Button.-danger:hover {
    background: #f08770;
}

#help-text {
    color: #e8e6e3;
    margin: 1 0;
}

#toast {
    dock: bottom;
    height: auto;
    background: transparent;
}

LoadingIndicator {
    color: #d97757;
}
